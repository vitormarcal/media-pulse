### Variables
@baseUrl = {{host}}/api/movies
@movieId = 1
@year = 2026
@start = 2026-01-01T00:00:00Z
@end = 2026-12-31T23:59:59Z

### Filmes recentes
GET {{baseUrl}}/recent?limit=20
Accept: application/json

### Detalhes do filme
GET {{baseUrl}}/{{movieId}}
Accept: application/json

### Detalhes do filme por slug
GET {{baseUrl}}/slug/eyes-wide-shut
Accept: application/json

### Detalhes de uma pessoa
GET {{baseUrl}}/people/quentin-tarantino-138
Accept: application/json

### Detalhes de uma empresa
GET {{baseUrl}}/companies/studio-ghibli-10342
Accept: application/json

### Detalhes de uma lista
GET {{baseUrl}}/lists/favoritos
Accept: application/json

### Listar listas
GET {{baseUrl}}/lists
Accept: application/json

### Buscar pessoas locais
GET {{baseUrl}}/people/search?q=quentin&limit=6
Accept: application/json

### Detalhes de um termo
GET {{baseUrl}}/terms/genre/horror
Accept: application/json

### Buscar termos existentes
GET {{baseUrl}}/terms/search?q=vamp&kind=tag&limit=6
Accept: application/json

### Busca de filmes
GET {{baseUrl}}/search?q=matrix&limit=10
Accept: application/json

### Resumo mensal
GET {{baseUrl}}/summary?range=month
Accept: application/json

### Resumo anual
GET {{baseUrl}}/summary?range=year
Accept: application/json

### Resumo personalizado
GET {{baseUrl}}/summary?range=custom&start={{start}}&end={{end}}
Accept: application/json

### Stats globais
GET {{baseUrl}}/stats
Accept: application/json

### Filmes por ano
GET {{baseUrl}}/year/{{year}}?limitWatched=200&limitUnwatched=200
Accept: application/json

### Backfill de colecoes oficiais TMDb
POST {{baseUrl}}/collections/backfill?limit=100000
Accept: application/json

### Membros TMDb de uma colecao
GET {{baseUrl}}/collections/1/tmdb-members
Accept: application/json

### Filmes TMDb de uma empresa
GET {{baseUrl}}/companies/12/tmdb-members
Accept: application/json

### Sincronizar termos do TMDb para um filme
POST {{baseUrl}}/{{movieId}}/terms/sync-tmdb
Accept: application/json

### Sincronizar empresas do TMDb para um filme
POST {{baseUrl}}/{{movieId}}/companies/sync-tmdb
Accept: application/json

### Sincronizar créditos do TMDb para um filme
POST {{baseUrl}}/{{movieId}}/credits/sync-tmdb
Accept: application/json

### Trazer pessoas extras do TMDb para um filme
GET {{baseUrl}}/{{movieId}}/credits/tmdb-candidates
Accept: application/json

### Incorporar um crédito específico do TMDb
POST {{baseUrl}}/{{movieId}}/credits/from-tmdb
Content-Type: application/json
Accept: application/json

{
  "personTmdbId": "138",
  "creditType": "CREW",
  "department": "Writing",
  "job": "Writer",
  "characterName": null,
  "billingOrder": null
}

### Vincular pessoa local a um filme
POST {{baseUrl}}/{{movieId}}/people
Content-Type: application/json
Accept: application/json

{
  "personId": 44,
  "group": "DIRECTORS",
  "roleLabel": null
}

### Criar lista manual
POST {{baseUrl}}/lists
Content-Type: application/json
Accept: application/json

{
  "name": "Favoritos",
  "description": "Filmes que sempre quero ter por perto."
}

### Adicionar filme a lista existente
POST {{baseUrl}}/{{movieId}}/lists
Content-Type: application/json
Accept: application/json

{
  "listId": 1,
  "name": null,
  "description": null
}

### Criar lista e adicionar o filme atual
POST {{baseUrl}}/{{movieId}}/lists
Content-Type: application/json
Accept: application/json

{
  "listId": null,
  "name": "Oscar 2025",
  "description": "Candidatos e vencedores para revisar."
}

### Remover filme de uma lista
DELETE {{baseUrl}}/{{movieId}}/lists/1
Accept: application/json

### Atualizar ordem completa de uma lista manual
POST {{baseUrl}}/lists/1/order
Content-Type: application/json
Accept: application/json

{
  "movieIds": [3, 1, 2]
}

### Sincronizar termos do TMDb em lote
POST {{baseUrl}}/terms/sync-tmdb?limit=200
Accept: application/json

### Sincronizar empresas do TMDb em lote
POST {{baseUrl}}/companies/sync-tmdb?limit=200
Accept: application/json

### Sincronizar créditos do TMDb em lote
POST {{baseUrl}}/credits/sync-tmdb?limit=200
Accept: application/json

### Filmografia TMDb de uma pessoa
GET {{baseUrl}}/people/1/tmdb-filmography
Accept: application/json

### Adicionar termo manual
POST {{baseUrl}}/{{movieId}}/terms
Content-Type: application/json
Accept: application/json

{
  "name": "Vampiros",
  "kind": "TAG"
}

### Ocultar termo apenas neste filme
POST {{baseUrl}}/{{movieId}}/terms/1/visibility
Content-Type: application/json
Accept: application/json

{
  "hidden": true
}

### Ocultar termo globalmente
POST {{baseUrl}}/terms/1/visibility
Content-Type: application/json
Accept: application/json

{
  "hidden": true
}

### Registrar watch manual (item unico)
POST {{baseUrl}}/watches
Content-Type: application/json
Accept: application/json

{
  "watchedAt": "2026-03-01T10:00:00Z",
  "title": "Dune",
  "year": 2021,
  "tmdbId": "438631",
  "imdbId": "tt1160419"
}
